{
  "rewrites": [
    {
      "source": "/dashboard/:match*",
      "destination": "/dashboard/:match*"
    },
    {
      "source": "/assets/:match*",
      "destination": "/assets/:match*"
    },
    {
      "source": "/track/:match*",
      "destination": "/track/:match*"
    },
    {
      "source": "/storefront/:match*",
      "destination": "/storefront/:match*"
    },
    {
      "source": "/verify",
      "destination": "/api/auth?action=verify"
    },
    {
      "source": "/product/:id([^/.]+)",
      "destination": "/api/og?id=:id"
    },
    {
      "source": "/product/:match*",
      "destination": "/product/:match*"
    },
    {
      "source": "/r",
      "destination": "/api/r"
    },
    {
      "source": "/notify",
      "destination": "/api/notify"
    },
    {
      "source": "/telegram",
      "destination": "/api/telegram"
    },
    {
      "source": "/:vendor([^/.]+)",
      "destination": "/api/og?vendor=:vendor"
    }
  ]
}
